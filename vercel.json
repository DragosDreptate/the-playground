{
  "ignoreCommand": "bash scripts/vercel-ignore.sh",
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "msl.the-playground.fr" }],
      "destination": "https://the-playground.fr/circles/le-club-de-mont-saint-leger",
      "permanent": true
    }
  ],
  "crons": [
    {
      "path": "/api/cron/recalculate-scores",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/send-reminders",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/posthog-daily-report",
      "schedule": "7 8 * * *"
    },
    {
      "path": "/api/cron/posthog-weekly-report",
      "schedule": "7 8 * * 1"
    },
    {
      "path": "/api/cron/send-onboarding-welcome",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/transition-past-moments",
      "schedule": "*/30 * * * *"
    }
  ]
}
