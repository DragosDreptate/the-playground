// ─────────────────────────────────────────────
// The Playground — Prisma Schema
// ─────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────

enum CircleVisibility {
  PUBLIC
  PRIVATE
}

enum CircleCategory {
  TECH
  DESIGN
  BUSINESS
  SPORT_WELLNESS
  ART_CULTURE
  SCIENCE_EDUCATION
  SOCIAL
  OTHER
}

enum CircleMemberRole {
  HOST
  PLAYER
}

enum LocationType {
  IN_PERSON
  ONLINE
  HYBRID
}

enum MomentStatus {
  DRAFT
  PUBLISHED
  CANCELLED
  PAST
}

enum RegistrationStatus {
  PENDING_APPROVAL
  REGISTERED
  WAITLISTED
  CANCELLED
  CHECKED_IN
  REJECTED
}

enum MembershipStatus {
  PENDING
  ACTIVE
}

enum PaymentStatus {
  NONE
  PENDING
  PAID
  REFUNDED
}

enum UserRole {
  USER
  ADMIN
}

enum DashboardMode {
  PARTICIPANT
  ORGANIZER
}

// ─────────────────────────────────────────────
// Auth.js models
// ─────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  access_token      String? @db.Text
  refresh_token     String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  sessionToken String   @unique
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─────────────────────────────────────────────
// Domain models
// ─────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  firstName     String?
  lastName      String?
  image                String?
  emailVerified        DateTime?
  onboardingCompleted       Boolean   @default(false)
  role                      UserRole  @default(USER)
  notifyNewRegistration     Boolean   @default(true)
  notifyNewComment          Boolean   @default(true)
  notifyNewMomentInCircle   Boolean   @default(true)
  bio                       String?   @db.VarChar(160)
  city                      String?
  website                   String?
  linkedinUrl               String?   @map("linkedin_url")
  twitterUrl                String?   @map("twitter_url")
  githubUrl                 String?   @map("github_url")
  dashboardMode             DashboardMode?
  publicId                  String?   @unique @map("public_id")
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  memberships   CircleMembership[]
  moments       Moment[]           @relation("CreatedMoments")
  registrations Registration[]
  comments      Comment[]
  radarUsages   RadarUsage[]

  @@map("users")
}

model Circle {
  id                    String           @id @default(cuid())
  slug                  String           @unique
  name                  String
  description           String           @db.Text
  logo                  String?
  coverImage            String?
  coverImageAttribution Json?            @db.JsonB
  visibility            CircleVisibility @default(PUBLIC)
  category              CircleCategory?
  customCategory        String?          @map("custom_category")
  city                  String?
  website               String?
  stripeConnectAccountId String?
  inviteToken           String?          @unique @map("invite_token")
  requiresApproval     Boolean   @default(false) @map("requires_approval")
  // Explorer scoring
  isDemo               Boolean   @default(false)
  excludedFromExplorer Boolean   @default(false)   @map("excluded_from_explorer")
  overrideScore        Int?                         @map("override_score")
  explorerScore        Int       @default(0)        @map("explorer_score")
  scoreUpdatedAt       DateTime?                    @map("score_updated_at")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships   CircleMembership[]
  moments       Moment[]

  // Index composite (visibility, category) : utilisé dans getPublicCircles (explorer)
  // WHERE visibility = 'PUBLIC' — couvert par le préfixe visibility
  // WHERE visibility = 'PUBLIC' AND category = ? — couvert par l'index complet
  @@index([visibility, category])
  // Index sur explorerScore : utilisé dans ORDER BY explorer_score DESC (Explorer)
  @@index([explorerScore])
  @@map("circles")
}

model CircleMembership {
  id       String           @id @default(cuid())
  userId   String
  circleId String
  role     CircleMemberRole
  status   MembershipStatus @default(ACTIVE)
  joinedAt DateTime         @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  circle Circle @relation(fields: [circleId], references: [id], onDelete: Cascade)

  @@unique([userId, circleId])
  // Index sur circleId+role : utilisé dans findMembersByRole, countMembers, findAllCircles (admin)
  @@index([circleId, role])
  // Index sur circleId+status : utilisé dans countMembers (WHERE status = ACTIVE), findPendingMemberships
  @@index([circleId, status])
  // Index sur userId : utilisé dans findByUserId, findAllByUserId, delete (user)
  @@index([userId])
  // Index composite (userId, role) : utilisé dans findAllByHostUserId — WHERE userId = ? AND role = 'HOST'
  @@index([userId, role])
  @@map("circle_memberships")
}

model Moment {
  id                    String       @id @default(cuid())
  slug                  String       @unique
  circleId              String
  createdById           String?
  title                 String
  description           String       @db.Text
  coverImage            String?
  coverImageAttribution Json?        @db.JsonB
  startsAt              DateTime
  endsAt                DateTime?
  locationType          LocationType
  locationName          String?
  locationAddress       String?
  videoLink             String?
  capacity              Int?
  price                 Int          @default(0)
  currency              String       @default("EUR")
  status                MomentStatus @default(PUBLISHED)
  refundable            Boolean      @default(true)
  requiresApproval     Boolean      @default(false) @map("requires_approval")
  broadcastSentAt       DateTime?
  reminder24hSentAt     DateTime?

  // Explorer scoring
  explorerScore Int @default(0) @map("explorer_score")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  circle    Circle @relation(fields: [circleId], references: [id], onDelete: Cascade)
  createdBy User?  @relation("CreatedMoments", fields: [createdById], references: [id], onDelete: SetNull)

  registrations Registration[]
  comments      Comment[]

  // Index sur circleId : utilisé dans findByCircleId, getCircleMoments
  @@index([circleId])
  // Index composite (status, startsAt) : utilisé dans findPublicUpcoming, transitionPastMoments, explorer
  @@index([status, startsAt])
  // Index sur (circleId, status) : utilisé dans findPublic (circles avec moments à venir)
  @@index([circleId, status])
  // Index sur explorerScore : utilisé dans ORDER BY explorer_score DESC (Explorer)
  @@index([explorerScore])
  @@map("moments")
}

model Registration {
  id                    String             @id @default(cuid())
  momentId              String
  userId                String
  status                RegistrationStatus @default(REGISTERED)
  paymentStatus         PaymentStatus      @default(NONE)
  stripePaymentIntentId String?
  stripeReceiptUrl      String?
  registeredAt          DateTime           @default(now())
  cancelledAt           DateTime?
  checkedInAt           DateTime?

  moment Moment @relation(fields: [momentId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([momentId, userId])
  // Index composite (momentId, status) : utilisé dans findActiveByMomentId, countByMomentIdAndStatus, findFirstWaitlisted
  @@index([momentId, status])
  // Index sur userId : utilisé dans findUpcomingByUserId, findPastByUserId
  @@index([userId])
  // Index composite (userId, status) : utilisé dans findAllForUserDashboard — WHERE userId = ? AND status IN [...]
  @@index([userId, status])
  @@map("registrations")
}

model Comment {
  id       String @id @default(cuid())
  momentId String
  userId   String
  content  String @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  moment Moment @relation(fields: [momentId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Index sur momentId : utilisé dans findByMomentIdWithUser, countByMomentId
  @@index([momentId])
  @@map("comments")
}

model RadarUsage {
  id     String @id @default(cuid())
  userId String
  date   String // "YYYY-MM-DD" UTC
  count  Int    @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@map("radar_usage")
}

model RateLimit {
  id          String   @id @default(cuid())
  key         String   @unique // ex: "contact:192.168.1.1"
  count       Int      @default(1)
  windowStart DateTime @default(now())

  @@map("rate_limits")
}

